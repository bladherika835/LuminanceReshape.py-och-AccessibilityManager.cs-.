using System;

namespace CrystalHorseWorld.Core
{
    /// <summary>
    /// Lead Architect implementation for Visual Accessibility.
    /// Bridges the gap between modern engines and legacy aesthetics.
    /// </summary>
    public class AccessibilityManager
    {
        public bool IsLegacyModeEnabled { get; set; } = true;
        public float TargetBrightness { get; private set; } = 0.45f;
        public bool DisableBloom { get; private set; } = true;

        public void ApplySafetyFilters()
        {
            if (IsLegacyModeEnabled)
            {
                // Forcing the engine to bypass high-contrast shaders
                DisableBloom = true;
                TargetBrightness = 0.45f; 
                
                Console.WriteLine("[CORE] Safety filters active: Bloom disabled, Brightness normalized.");
                Console.WriteLine("[CORE] Emulating 2011-2017 matte rendering for light sensitivity.");
            }
        }

        public void LogTechnicalStatus()
        {
            Console.WriteLine($"Current Engine State: LegacyMode={IsLegacyModeEnabled} | Bloom={!DisableBloom}");
        }
    }
}

